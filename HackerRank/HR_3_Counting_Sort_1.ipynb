      "source": [
        "#Counting Sort\n",
        "def countingSort(arr):\n",
        "    freq = [0] * 100\n",
        "\n",
        "    for num in arr:\n",
        "        freq[num] += 1\n",
        "\n",
        "    return freq\n",
        "\n",
        "\n",
        "arr = [1, 1, 3, 2, 1]\n",
        "print(countingSort(arr))"
      ]
    }
  ]
